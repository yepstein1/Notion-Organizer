version = 0.1

[default.deploy.parameters]
stack_name = "notion-organizer"
region = "us-east-2"
capabilities = "CAPABILITY_IAM"
confirm_changeset = true
resolve_s3 = true
s3_prefix = "notion-organizer"
disable_rollback = true
image_repositories = []
parameter_overrides = "NotionToken=\"secret_xxxx\" AnthropicApiKey=\"sk-ant-xxxx\" NotionDatabaseId=\"your-database-id\""
